# Must be the SAME MongoDB cluster/connection string used by the bot
# service, so ad-redirect tokens created by the bot are resolvable here.
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# Must match the DB_NAME set on the bot service (defaults to campus_post_bot)
DB_NAME=campus_post_bot

# Text shown on the landing page footer
BRAND_NAME=Campus Post

# Render sets this automatically — only needed for local testing
PORT=8080
